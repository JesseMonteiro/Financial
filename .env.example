# Configurações do Servidor
PORT=3001

# Credenciais Pluggy.ai (obtenha em https://dashboard.pluggy.ai)
PLUGGY_CLIENT_ID=your_client_id_here
PLUGGY_CLIENT_SECRET=your_client_secret_here

# Supabase (obtenha em https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Telegram chatbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Gemini (linguagem natural no chatbot)
GEMINI_API_KEY=your_gemini_api_key_here
